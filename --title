  --font-size-md: 16px;
  --font-size-lg: 20px;
  --font-size-xl: 24px;
  --font-size-2xl: 32px;

  --font-weight-regular: 400;
  --font-weight-medium: 500;
  --font-weight-semibold: 600;
  --font-weight-bold: 700;

  --line-height-tight: 1.25;
  --line-height-normal: 1.5;
  --line-height-relaxed: 1.625;

  /* === Spacing (4px base) === */
  --space-1: 4px;
  --space-2: 8px;
  --space-3: 12px;
  --space-4: 16px;
  --space-5: 20px;
  --space-6: 24px;
  --space-8: 32px;
  --space-10: 40px;
  --space-12: 48px;

  /* === Sizing === */
  --size-button-md: 40px;
  --size-button-lg: 48px;
  --size-input-height: 40px;
  --size-icon-sm: 16px;
  --size-icon-md: 20px;
  --size-icon-lg: 24px;
  --size-avatar-sm: 32px;
  --size-avatar-md: 40px;
  --size-avatar-lg: 56px;

  /* === Border Radius === */
  --radius-sm: 4px;
  --radius-button: 6px;
  --radius-card: 8px;
  --radius-modal: 12px;
  --radius-lg: 16px;
  --radius-full: 9999px;

  /* === Shadows === */
  --shadow-1: 0 1px 2px rgba(0, 0, 0, 0.04); /* Subtle */
  --shadow-2: 0px 4px 16px rgba(77, 168, 255, 0.08); /* Float */

  /* === Layout === */
  --content-max-width: 1280px;
  --mobile-breakpoint: 768px;
  --sidebar-width: 280px;
  --header-height: 56px;
  --page-padding: 32px;
  --page-padding-mobile: 16px;

  /* === Atmosphere Glow === */
  --atmosphere-glow: radial-gradient(600px at 50% 30%, rgba(77, 168, 255, 0.04), transparent);
}

/* === Typography Classes === */
.sf-display  { font-family: var(--font-body); font-size: 2rem; font-weight: var(--font-weight-bold); line-height: var(--line-height-tight); letter-spacing: -0.02em; }
