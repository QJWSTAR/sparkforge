# SparkForge 环境变量配置示例
# 复制此文件为 .env.local 并填入真实值

# ==================== 数据库 ====================
# Supabase 项目 URL（从项目设置页获取）
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase Anon Key（公开密钥，可暴露给前端）
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase Service Role Key（服务端密钥，仅用于服务端）
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ==================== LLM API ====================
# DeepSeek API Key（用于评分）
DEEPSEEK_API_KEY=your-deepseek-api-key

# ==================== 信号源 API ====================
# Product Hunt API Token
PRODUCTHUNT_ACCESS_TOKEN=your-producthunt-access-token

# Algolia API Key（用于 Hacker News 搜索）
ALGOLIA_API_KEY=your-algolia-api-key

# ==================== Cron ====================
# Cron API Key（用于保护定时任务API，可自行生成随机字符串）
CRON_API_KEY=your-cron-api-key
