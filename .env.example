# SparkForge 环境变量配置示例
# 复制此文件为 .env.local 并填入真实值

# ==================== 数据库 ====================
# Supabase 项目 URL（从项目设置页获取）
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase Anon Key（公开密钥，可暴露给前端）
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase Service Role Key（服务端密钥，仅用于服务端）
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ==================== LLM API ====================
# DeepSeek API Key（用于评分）
DEEPSEEK_API_KEY=your-deepseek-api-key

# MiMo API Key（用于粗筛）
MIMO_API_KEY=your-mimo-api-key

# OpenAI API Key（可选，用于精排）
OPENAI_API_KEY=your-openai-api-key

# ==================== TRAE IDE ====================
# TRAE IDE API Key（用于一键复刻功能）
TRAE_API_KEY=your-trae-api-key

# TRAE API Endpoint
TRAE_API_ENDPOINT=https://api.trae.cn/v1

# ==================== 部署 ====================
# Vercel Token（用于自动部署）
VERCEL_TOKEN=your-vercel-token

# ==================== 信号源 API ====================
# Product Hunt API Token
PRODUCTHUNT_ACCESS_TOKEN=your-producthunt-access-token

# Algolia API Key（用于 Hacker News 搜索）
ALGOLIA_API_KEY=your-algolia-api-key
ALGOLIA_APP_ID=your-algolia-app-id

# ==================== Redis ====================
# Upstash Redis URL
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io

# Upstash Redis Token
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# ==================== 监控 ====================
# Sentry DSN（可选，用于错误监控）
SENTRY_DSN=https://your-sentry-dsn

# PostHog Key（可选，用于分析）
POSTHOG_KEY=your-posthog-key

# ==================== 支付 ====================
# Stripe Secret Key（用于支付）
STRIPE_SECRET_KEY=your-stripe-secret-key

# Stripe Publishable Key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key