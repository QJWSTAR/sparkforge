generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Signal {
  id            String        @id @default(uuid())
  source        String
  sourceId      String
  title         String
  description   String?
  url           String?
  imageUrl      String?
  tags          String[]      @default([])
  author        String?
  votesCount    Int           @default(0)
  commentsCount Int           @default(0)
  hotScore      Float         @default(0)
  noveltyScore  Float?
  businessScore Float?
  localScore    Float?
  finalScore    Float?
  scoreVersion  String?
  status        SignalStatus  @default(PENDING)
  rawData       Json?
  fetchedAt     DateTime      @default(now())
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  forgeProjects ForgeProject[]
  canvasReports CanvasReport[]
  logEntries    LogEntry[]

  @@unique([source, sourceId])
  @@index([status, finalScore])
  @@index([source, fetchedAt])
}

enum SignalStatus {
  PENDING
  SCREENED
  SCORED
  TOP10
  ARCHIVED
}

model ForgeProject {
  id              String           @id @default(uuid())
  signalId        String
  signal          Signal           @relation(fields: [signalId], references: [id])
  status          ForgeStatus      @default(PENDING)
  targetLanguage  String           @default("zh-CN")
  customPrompt    String?
  localScore      Float?
  outputUrl       String?
  outputRepoUrl   String?
  outputPreviewUrl String?
  outputSummary   String?
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  logEntries      LogEntry[]

  @@index([status, createdAt])
}

enum ForgeStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model CanvasReport {
  id         String     @id @default(uuid())
  signalId   String
  signal     Signal     @relation(fields: [signalId], references: [id])
  positioning String?
  userPersona String?
  competitors Json?
  monetization String?
  actionPlan  Json?
  fullReport  Json?
  status     CanvasStatus @default(PENDING)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([status, createdAt])
}

enum CanvasStatus {
  PENDING
  GENERATING
  COMPLETED
  FAILED
}

model LogEntry {
  id        String        @id @default(uuid())
  signalId  String?
  signal    Signal?       @relation(fields: [signalId], references: [id])
  forgeId   String?
  forgeProject ForgeProject? @relation(fields: [forgeId], references: [id])
  type      LogType
  title     String
  content   String?
  metadata  Json?
  createdAt DateTime      @default(now())

  @@index([type, createdAt])
}

enum LogType {
  SIGNAL_DISCOVERED
  SIGNAL_SCORED
  SIGNAL_TOP10
  FORGE_STARTED
  FORGE_PROGRESS
  FORGE_COMPLETED
  CANVAS_GENERATED
  SYSTEM
}

model UserSetting {
  id       String   @id @default(uuid())
  userId   String   @unique
  sources  String[] @default([])
  categories String[] @default([])
  minScore Float    @default(0)
  notify   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Profile {
  id        String   @id @db.Uuid
  email     String   @unique
  name      String?
  avatarUrl String?  @map("avatar_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("profiles")
}
