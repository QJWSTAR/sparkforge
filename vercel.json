{
  "crons": [
    {
      "path": "/api/crawl",
      "schedule": "0 0 * * *",
      "headers": {
        "Authorization": "Bearer ${CRON_API_KEY}"
      }
    },
    {
      "path": "/api/score/batch",
      "schedule": "0 1 * * *",
      "headers": {
        "Authorization": "Bearer ${CRON_API_KEY}"
      }
    }
  ]
}
